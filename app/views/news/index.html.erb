<%= render ModuleHeaderComponent.new(
    title: "Noticias",
    description: "Consulta un resumen diario con las noticias economicas mas relevantes y sus fuentes principales."
  ) do %>

  <section class="bg-white shadow-sm rounded-2xl p-6 sm:p-8 mb-10 border border-slate-200 min-h-[calc(100vh-16rem)]">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-6">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-3">
        <h2 class="text-2xl font-semibold text-slate-900">Resumen - <%= @selected_date.strftime("%d/%m/%Y") %></h2>
        <% if @summary %>
          <p class="inline-flex items-center px-3 py-1 bg-white border border-violet-700 text-violet-700 text-sm font-medium rounded-xl whitespace-nowrap">
            <%= @summary.sources_count %> fuentes consultadas
          </p>
        <% end %>
      </div>
      <div
        class="relative max-w-sm"
        data-controller="news-datepicker"
        data-news-datepicker-url-value="<%= news_index_path %>"
        data-news-datepicker-max-date-value="<%= @today.iso8601 %>"
      >
        <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
          <svg class="w-4 h-4 text-body" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 10h16m-8-3V4M7 7V4m10 3V4M5 20h14a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Zm3-7h.01v.01H8V13Zm4 0h.01v.01H12V13Zm4 0h.01v.01H16V13Zm-8 4h.01v.01H8V17Zm4 0h.01v.01H12V17Zm4 0h.01v.01H16V17Z"/></svg>
        </div>
        <input
          datepicker
          datepicker-autohide
          datepicker-format="dd/mm/yyyy"
          datepicker-max-date="<%= @today.strftime("%d/%m/%Y") %>"
          id="news-date-input"
          type="text"
          data-news-datepicker-target="input"
          value="<%= @selected_date.strftime("%d/%m/%Y") %>"
          class="block w-full ps-9 pe-3 py-2.5 bg-neutral-secondary-medium border border-default-medium text-heading text-sm rounded-base focus:ring-brand focus:border-brand px-3 py-2.5 shadow-xs placeholder:text-body cursor-pointer"
          placeholder="Selecciona una fecha"
          autocomplete="off">
      </div>
    </div>

    <% if @summary %>

      <div class="space-y-5 leading-relaxed text-slate-700">
        <% @summary.summary.to_s.split("\n").each do |line| %>
          <% text = line.to_s.strip %>
          <% next if text.blank? %>

          <% if text.ends_with?(":") %>
            <h3 class="text-lg font-semibold text-slate-900 pt-2 first:pt-0"><%= text %></h3>
          <% elsif text.start_with?("- ") %>
            <div class="flex items-start gap-3">
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-slate-500 flex-shrink-0"></span>
              <p class="text-base"><%= text.delete_prefix("- ").strip %></p>
            </div>
          <% else %>
            <p class="text-base"><%= text %></p>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-slate-50 border border-slate-200 rounded-xl p-5 text-slate-700">
        No hay resumen disponible para el <%= @selected_date.strftime("%d/%m/%Y") %>. Puedes navegar a otra fecha o actualizar las noticias.
      </div>
    <% end %>
  </section>

  <% if @news_items.any? %>
    <section>
      <h3 class="text-xl font-semibold text-slate-900 mb-4">Noticias</h3>
      <div class="space-y-4">
        <% @news_items.each do |item| %>
          <%= render NewsItemComponent.new(item: item) %>
        <% end %>
      </div>
    </section>
  <% end %>
<% end %>
