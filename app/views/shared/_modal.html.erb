<div
  id="snapshot-modal"
  tabindex="-1"
  aria-hidden="true"
  data-action="click->snapshot-modal#closeOnBackdrop keydown.esc@window->snapshot-modal#close"
  class="hidden overflow-y-auto overflow-x-hidden fixed inset-0 z-50 justify-center items-center w-full max-h-full bg-black/80">
  <div class="relative p-4 w-full max-w-2xl max-h-full">
    <div class="relative bg-white rounded-lg shadow-sm">
      <div class="flex items-center justify-between p-4 border-b rounded-t border-gray-200">
        <h3 id="modal-title" class="text-xl font-bold text-gray-900">Detalle</h3>
        <button
          type="button"
          data-action="click->snapshot-modal#close"
          class="text-gray-400 hover:text-gray-600 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center cursor-pointer">
          <span class="sr-only">Cerrar modal</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="p-6 space-y-6">
        <div data-snapshot-modal-target="loader" class="hidden flex justify-center items-center py-12">
          <svg class="animate-spin h-10 w-10 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>

        <div id="modal-content" data-snapshot-modal-target="content" class="hidden"></div>
      </div>

      <div class="flex items-center p-4 border-t border-gray-200 rounded-b">
        <button
          type="button"
          data-action="click->snapshot-modal#close"
          class="w-full inline-flex items-center justify-center px-3 py-1.5 bg-violet-700 text-white text-sm font-medium rounded-xl shadow hover:bg-violet-800 cursor-pointer">
          Cerrar
        </button>
      </div>
    </div>
  </div>
</div>
