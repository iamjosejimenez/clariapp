<%= render ModuleHeaderComponent.new(
    title: "Correos del banco",
    description: "Correos de notificación importados desde tu cuenta de Gmail. Aquí se almacenan tal como llegan, listos para procesar."
  ) do %>
  <section class="bg-white shadow-sm rounded-2xl p-6 sm:p-8 border border-slate-200 min-h-[calc(100vh-16rem)]">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-semibold text-slate-900">Correos recibidos</h2>
      <% if current_user.gmail_account.blank? %>
        <%= link_to gmail_sessions_new_path, class: "inline-flex items-center px-3 py-1.5 bg-violet-700 text-white text-sm font-medium rounded-xl shadow hover:bg-violet-800" do %>
          Conectar Gmail
        <% end %>
      <% else %>
        <div class="flex items-center gap-2">
          <%= link_to gmail_sessions_new_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-xl border border-slate-200 hover:bg-slate-200" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
            Sincronizar
          <% end %>

          <%# Desconectar borra la gmail_account (y por dependent: :destroy sus
              bank_emails), permitiendo conectar otra casilla desde cero. %>
          <%= button_to gmail_sessions_path, method: :delete,
                data: { turbo_confirm: "¿Seguro que quieres desconectar #{current_user.gmail_account.email}? Se eliminarán también los correos importados de esta cuenta." },
                class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-xl border border-slate-200 hover:bg-red-50 hover:text-red-600 hover:border-red-200 cursor-pointer" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
            Desconectar
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @bank_emails.any? %>
      <%= render TableComponent.new(rows: @bank_emails) do |table| %>
        <% table.with_column(name: "Recibido", classes: "text-left text-gray-700") do |bank_email| %>
          <%= chile_datetime(bank_email.received_at) %>
        <% end %>

        <% table.with_column(name: "Remitente", classes: "text-left text-gray-700") do |bank_email| %>
          <%= bank_email.from_address %>
        <% end %>

        <% table.with_column(name: "Asunto", classes: "text-left font-medium text-gray-900") do |bank_email| %>
          <%= bank_email.subject %>
        <% end %>

        <% table.with_column(name: "Resumen", classes: "text-left text-gray-500") do |bank_email| %>
          <span class="line-clamp-1"><%= bank_email.snippet %></span>
        <% end %>

        <% table.with_column(name: "Acciones", classes: "text-right") do |bank_email| %>
          <button
            data-action="click->snapshot-modal#open"
            data-url="<%= detail_bank_email_path(bank_email) %>"
            class="inline-flex items-center justify-center w-8 h-8 rounded-lg hover:bg-slate-100 text-slate-500 hover:text-violet-700 cursor-pointer"
            title="Ver detalle">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.641 0-8.573-3.007-9.964-7.178Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
          </button>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-gray-500">
        Aún no hay correos importados.
        <% if current_user.gmail_account.present? %>
          Se importarán automáticamente desde <%= current_user.gmail_account.email %>.
        <% else %>
          Conecta tu cuenta de Gmail para empezar.
        <% end %>
      </p>
    <% end %>
  </section>
<% end %>
