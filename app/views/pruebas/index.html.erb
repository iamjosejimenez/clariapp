<div class="max-w-lg mx-auto mt-16 p-8 bg-white rounded-xl shadow space-y-6">
  <h1 class="text-2xl font-bold text-gray-800">Prueba HTMX</h1>

  <p class="text-gray-500">Haz clic en el botón para cargar contenido sin recargar la página.</p>

  <button
    hx-get="<%= pruebas_mensaje_path %>"
    hx-target="#resultado"
    hx-swap="innerHTML"
    data-turbo="false"
    class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer">
    Obtener mensaje
  </button>

  <div id="resultado" class="p-4 bg-gray-50 rounded border border-gray-200 text-gray-600 min-h-[60px]">
    El resultado aparecerá aquí...
  </div>
</div>
