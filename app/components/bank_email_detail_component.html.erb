<div class="space-y-3">
  <div class="border-b pb-2">
    <p class="text-sm text-gray-600">Recibido</p>
    <p class="text-lg font-semibold text-gray-900"><%= chile_datetime(@bank_email.received_at) %></p>
  </div>

  <div class="border-b pb-2">
    <p class="text-sm text-gray-600">Remitente</p>
    <p class="text-lg font-semibold text-gray-900"><%= @bank_email.from_address %></p>
  </div>

  <div class="border-b pb-2">
    <p class="text-sm text-gray-600">Asunto</p>
    <p class="text-lg font-semibold text-gray-900"><%= @bank_email.subject %></p>
  </div>

  <div class="border-b pb-2">
    <p class="text-sm text-gray-600">Resumen</p>
    <p class="text-gray-700"><%= @bank_email.snippet %></p>
  </div>

  <div>
    <p class="text-sm text-gray-600">Contenido</p>
    <div class="mt-1 text-sm text-gray-800 bg-slate-50 rounded-lg p-3 max-h-64 overflow-y-auto whitespace-pre-wrap"><%= @bank_email.raw_body.presence || "Sin contenido disponible." %></div>
  </div>
</div>
