<div class="space-y-3">
  <div class="border-b pb-2">
    <p class="text-sm text-gray-600">Fecha</p>
    <p class="text-lg font-semibold text-gray-900"><%= chile_date(@snapshot.created_at) %></p>
  </div>

  <div class="border-b pb-2">
    <p class="text-sm text-gray-600">Total (NAV)</p>
    <p class="text-lg font-semibold text-green-600"><%= clp(@snapshot.nav) %></p>
  </div>

  <div class="border-b pb-2">
    <p class="text-sm text-gray-600">Ganancia</p>
    <p class="text-lg font-semibold <%= @snapshot.profit.to_i < 0 ? "text-red-600" : "text-green-600" %>">
      <%= clp(@snapshot.profit) %>
    </p>
  </div>

  <div class="border-b pb-2">
    <p class="text-sm text-gray-600">Depositado</p>
    <p class="text-lg font-semibold text-gray-900"><%= clp(@snapshot.deposited) %></p>
  </div>

  <div class="border-b pb-2">
    <p class="text-sm text-gray-600">Retirado</p>
    <p class="text-lg font-semibold text-gray-900"><%= clp(@snapshot.withdrawn) %></p>
  </div>

  <div>
    <p class="text-sm text-gray-600">Neto no Depositado</p>
    <p class="text-lg font-semibold text-gray-900"><%= clp(@snapshot.not_net_deposited) %></p>
  </div>
</div>
