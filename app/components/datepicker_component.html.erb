<div
  class="<%= container_classes %>"
  <% if attach_controller? %>
    data-controller="<%= controller_name %>"
    data-<%= controller_name %>-url-value="<%= url %>"
    <% if max_date_iso8601.present? %> data-<%= controller_name %>-max-date-value="<%= max_date_iso8601 %>"<% end %>
    <% if selected_date_iso8601.present? %> data-<%= controller_name %>-selected-date-value="<%= selected_date_iso8601 %>"<% end %>
  <% end %>>
  <label for="<%= id %>" class="block text-sm font-medium text-slate-700 mb-1"><%= label %></label>
  <div class="relative">
    <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
      <svg class="w-4 h-4 text-body" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 10h16m-8-3V4M7 7V4m10 3V4M5 20h14a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Zm3-7h.01v.01H8V13Zm4 0h.01v.01H12V13Zm4 0h.01v.01H16V13Zm-8 4h.01v.01H8V17Zm4 0h.01v.01H12V17Zm4 0h.01v.01H16V17Z" />
      </svg>
    </div>
    <input
      datepicker
      datepicker-autohide
      datepicker-format="<%= datepicker_format %>"
      <% if max_date_for_picker.present? %> datepicker-max-date="<%= max_date_for_picker %>"<% end %>
      id="<%= id %>"
      type="text"
      <% if controller_name.present? && target_name.present? %> data-<%= controller_name %>-target="<%= target_name %>"<% end %>
      value="<%= value %>"
      class="<%= input_classes %>"
      placeholder="<%= placeholder %>"
      autocomplete="off"
      readonly
      aria-readonly="true">
  </div>
</div>
